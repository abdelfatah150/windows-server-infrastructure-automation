# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|

  # Global Configuration
  config.vm.box_check_update = false

  # WinRM Configuration
  config.winrm.timeout = 1000
  config.winrm.retry_limit = 3
  config.vm.boot_timeout = 1000

  # Primary Domain Controller (PDC)
  config.vm.define "PDC" do |pdc|

    pdc.vm.box = "StefanScherer/windows_2019"
    pdc.vm.box_version = "2020.02.12"

    pdc.vm.hostname = "PDC"

    pdc.vm.network "private_network", ip: "192.168.10.2"

    pdc.vm.provider "hyperv" do |hy|
      hy.memory = 2048
      hy.cpus = 2
    end

    # Phase 1
    pdc.vm.provision "shell",
      path: "../Scripts/Phase1/PDC/InitialSetup.ps1",
      reboot: true

    # Phase 2
    pdc.vm.provision "shell",
      path: "../Scripts/Phase2/PDC/SetupDomain.ps1"

    pdc.vm.provision "shell",
      path: "../Scripts/Phase2/PDC/EnableRecycleBin.ps1"

    # Phase 3
    pdc.vm.provision "shell",
      path: "../Scripts/Phase3/CreateOUs.ps1"

    pdc.vm.provision "shell",
      path: "../Scripts/Phase3/CreateGroups.ps1"

    pdc.vm.provision "shell",
      path: "../Scripts/Phase3/CreateUsers.ps1"

    pdc.vm.provision "shell",
      path: "../Scripts/Phase3/PasswordPolicy.ps1"

    # Phase 4
    pdc.vm.provision "shell",
      path: "../Scripts/Phase4/ConfigureDHCP.ps1"

    pdc.vm.provision "shell",
      path: "../Scripts/Phase4/ConfigureDHCPFailover.ps1"

    pdc.vm.provision "shell",
      path: "../Scripts/Phase4/ConfigureDNS.ps1"

    pdc.vm.provision "shell",
      path: "../Scripts/Phase4/ConfigureIIS.ps1"


  end

  # Additional Domain Controller (ADC)
  config.vm.define "ADC" do |adc|

    adc.vm.box = "StefanScherer/windows_2019"
    adc.vm.box_version = "2020.02.12"

    adc.vm.hostname = "ADC"

    adc.vm.network "private_network", ip: "192.168.10.3"

    adc.vm.provider "hyperv" do |hy|
      hy.memory = 2048
      hy.cpus = 2
    end

    # Phase 1
    adc.vm.provision "shell",
      path: "../Scripts/Phase1/ADC/InitialSetup.ps1",
      reboot: true

    # Phase 2
    adc.vm.provision "shell",
      path: "../Scripts/Phase2/ADC/SetupADC.ps1"

    # Phase 4
    adc.vm.provision "shell",
      path: "../Scripts/Phase4/ConfigureIIS.ps1"

  end

  # Client
  config.vm.define "CLIENT" do |client|

    client.vm.box = "gusztavvargadr/windows-11-24h2-enterprise"

    client.vm.hostname = "CLIENT"

    client.vm.network "private_network", ip: "192.168.10.10"

    client.vm.provider "hyperv" do |hy|
      hy.memory = 2048
      hy.cpus = 2
    end

    # Phase 1
    client.vm.provision "shell",
      path: "../Scripts/Phase1/CLIENT/InitialSetup.ps1",
      reboot: true

    # Phase 2
    client.vm.provision "shell",
      path: "../Scripts/Phase2/CLIENT/JoinDomain.ps1"

  end

end